# ── Wallet (Polygon EOA) ──────────────────────────────────────────────────────
# Your Ethereum private key (0x-prefixed). NEVER commit this file.
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Polygon RPC endpoint (free tier works fine for read operations)
POLYGON_RPC=https://polygon-rpc.com

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create a bot via @BotFather, then start a chat and get your chat ID.
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRstUVwxYZ
TELEGRAM_CHAT_ID=987654321

# ── Optional overrides ────────────────────────────────────────────────────────
# Uncomment to override defaults defined in bot/config.py
# STARTING_BALANCE=50.0
# MAX_POSITION_ABS=5.0
# MIN_EDGE=0.10
# DAILY_LOSS_LIMIT=2.0
# LOOP_INTERVAL=120
